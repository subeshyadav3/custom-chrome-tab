# ============================================
# Custom New Tab - Environment Variables
# ============================================
# Copy env-config.example.js to env-config.js and edit.
# This file documents available config options.

# Your display name shown on the page
USER_NAME=Your Name

# Top bar links (comma-separated: name|url)
TOP_BAR_LINKS=Gmail|https://mail.google.com/,Facebook|https://www.facebook.com/,Account|https://myaccount.google.com/

# Search engine
SEARCH_ACTION=https://www.google.com/search
SEARCH_QUERY_PARAM=q
SEARCH_PLACEHOLDER=Search Google...

# Suggest API URL (leave empty to disable autocomplete)
SUGGEST_API=https://suggestqueries.google.com/complete/search?client=firefox&q=

# Favicon service URL (use {domain} as placeholder)
FAVICON_SERVICE=https://www.google.com/s2/favicons?domain={domain}&sz=64
